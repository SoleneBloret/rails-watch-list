<div class="container">
  <h1><%= @list.name %></h1>

  <%= link_to "Add bookmark", new_list_bookmark_path(@list) %>
  <br>

  <div class="row row-cols-1 row-cols-md-2 g-4">
    <div class="col">
      <% @bookmarks.each do |bookmark| %>
        <div class="card">
          <img src="<%= bookmark.movie.poster_url %>" class="card-img-top" alt="movie poster">
          <div class="card-body">
            <h5 class="card-title"><%= bookmark.movie.title %> <span>⭐️ <%= bookmark.movie.rating.to_i %>/10</span></h5>
            <p class="card-text"><%= bookmark.movie.overview %></p>
            <p class="card-text" id="bookmark-card-comment">"<%= bookmark.comment %>"</p>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <br>
  <%= link_to "Homepage", root_path %>
</div>
