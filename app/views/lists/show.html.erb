<div class="container">
  <h1><%= @list.name %></h1>

  <%= link_to "Add bookmark", new_list_bookmark_path(@list) %>
  <br>

  <ul>
    <% @bookmarks.each do |bookmark| %>
      <li>
        <%= bookmark.movie.title %>
        <p><%= bookmark.comment %></p>
        <p>⭐️ <%= bookmark.movie.rating.to_i %>/10</p>
      </li>
    <% end %>
  </ul>

  <br>
  <%= link_to "Homepage", root_path %>
</div>
